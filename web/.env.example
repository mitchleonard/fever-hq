# Fever HQ — env vars. Copy to .env.local for dev, set in Vercel for prod.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me

# Web Push (generate with: npm run vapid)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-me
VAPID_PRIVATE_KEY=replace-me
VAPID_CONTACT_EMAIL=mailto:mitch@mitchleonard.com

# Subscription storage (single-user MVP — paste the wife's push subscription JSON here)
# Get this by enabling notifications in the deployed app, then copying from /api/push/debug.
WIFE_PUSH_SUBSCRIPTION_JSON=

# Vercel cron auth — generate a random 32-char string
CRON_SECRET=replace-with-random-string

# Optional dev override: force channel state ("sms" | "email" — for testing season detector)
# Production: leave unset.
# FEVER_HQ_CHANNEL_OVERRIDE=
