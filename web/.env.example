# Fever HQ — env vars. Copy to .env.local for dev, set in Vercel for prod.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me

# Web Push (generate with: npm run vapid)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-me
VAPID_PRIVATE_KEY=replace-me
VAPID_CONTACT_EMAIL=mailto:mitch@mitchleonard.com

# Subscription storage (no DB — paste push subscription JSON directly).
# Get a subscription by enabling notifications in the deployed app on a
# device, then copying the JSON from the Vercel logs line
# "[push/subscribe] received subscription:". Pregame pushes go out to
# every subscriber env var below that's set.
# Verify wiring anytime with GET /api/push/debug (Authorization: Bearer
# <CRON_SECRET>), or fire an on-demand test push with GET /api/push/test
# (same auth) without waiting for a real game.
WIFE_PUSH_SUBSCRIPTION_JSON=
TESTER_PUSH_SUBSCRIPTION_JSON=

# Vercel cron auth — generate a random 32-char string. Also set this (and
# FEVER_HQ_URL) as GitHub repo secrets so .github/workflows/pregame-cron.yml
# can ping /api/cron/pregame every 15 min — Vercel Hobby only allows daily
# cron, so without this external pinger no pregame push ever fires.
CRON_SECRET=replace-with-random-string

# Optional dev override: force channel state ("sms" | "email" — for testing season detector)
# Production: leave unset.
# FEVER_HQ_CHANNEL_OVERRIDE=
