# Fever HQ — copy to .env, fill in, then upload to Vercel project settings.
# NEVER commit the real .env to git.

# Twilio
TWILIO_ACCOUNT_SID=AC_replace_me
TWILIO_AUTH_TOKEN=replace_me
TWILIO_FROM_NUMBER=+13175551234

# Anthropic
ANTHROPIC_API_KEY=sk-ant-replace-me

# Destinations
FEVER_HQ_WIFE_NUMBER=+1...

# Dev safety net: if set, ALL outbound SMS route here instead of FEVER_HQ_WIFE_NUMBER.
# Set this to YOUR own number until you've passed end-to-end test.
TWILIO_FORCE_TEST_TO=+1_YOUR_OWN_NUMBER

# Optional: override the season detector for testing (sms|email).
# Leave unset in production.
# FEVER_HQ_CHANNEL_OVERRIDE=
